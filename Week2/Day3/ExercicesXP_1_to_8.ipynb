    print(f"Erreur : Le fichier '{file_path}' est introuvable.")


df = pd.read_csv(
    "/content/Airplane_Crashes_and_Fatalities_Since_1908_t0_2023.csv",
    encoding='latin1'
)
print(df.head())
print(df.shape)
print(df.info())

print(df.isnull().sum())
df["Date"] = pd.to_datetime(
    df["Date"],
   
 errors="coerce")


df = df.dropna(subset=["Date"])
numeric_cols = [
    "Aboard",
    "Fatalities",
    "Ground"
]

for col in numeric_cols:
    df[col] = df[col].fillna(0)
df["Year"] = df["Date"].dt.year

df["Decade"] = (
    df["Year"] // 10
) * 10

# Correction : Accès aux colonnes via le DataFrame df
df["Survivors"] = df["Aboard"] - df["Fatalities"]

# Affichage des premières lignes pour vérifier
display(df[["Year", "Decade", "Aboard", "Fatalities", "Survivors"]].head())
df["Survivors"] = (
    df["Aboard"] -
    df["Fatalities"]
)

df["Survival_Rate"] = (
    df["Survivors"] /
    df["Aboard"]
) * 100
total_crashes = len(df)

print(
    f"Total crashes: {total_crashes}"
)
total_fatalities = (
    df["Fatalities"].sum()
)

print(total_fatalities)
print(
    df[
        ["Fatalities",
         "Survival_Rate"]
    ].describe()
)
print(
    df[
        ["Fatalities",
         "Survival_Rate"]
    ].describe()
)
crashes_per_year = (
    df.groupby("Year")
      .size()
)
plt.figure(figsize=(12,6))

crashes_per_year.plot()

plt.title(
    "Airplane Crashes per Year"
)

plt.xlabel("Year")
plt.ylabel("Number of Crashes")

plt.grid()

plt.show()
decade_crashes = (
    df.groupby("Decade")
      .size()
)



Interprétation

Puisque : p < 0.05
on rejette H0.

Conclusion :

Les fatalités moyennes diffèrent significativement entre les deux périodes.

