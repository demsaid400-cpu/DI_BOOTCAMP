print("="*60)

class SentimentAnalyzer:
    """Production-ready sentiment analyzer with explainability features"""
    
    def __init__(self, model_path='./best_model'):
        """Initialize the analyzer with a trained model"""
        self.device = torch.device('cuda' if torch.cuda.is_available() else 'cpu')
        self.tokenizer = AutoTokenizer.from_pretrained(model_path)
        self.model = AutoModelForSequenceClassification.from_pretrained(model_path)
        self.model.to(self.device)
        self.model.eval()
        self.base_model = AutoModel.from_pretrained(model_path, output_attentions=True)
        self.base_model.to(self.device)
        self.base_model.eval()
        self.label_names = ['negative', 'neutral', 'positive']
        self.softmax = torch.nn.Softmax(dim=1)
    
    def analyze(self, text, return_attention=True):
        """
        Analyze sentiment with explainability features
        
        Args:
            text (str): Input text to analyze
            return_attention (bool): Whether to return attention weights
            
        Returns:
            dict: Prediction results with confidence and highlighted tokens
        """
        # Tokenize
        inputs = self.tokenizer(
            text,
            truncation=True,
            padding='max_length',
            max_length=128,
            return_tensors='pt'
        )
        inputs = {k: v.to(self.device) for k, v in inputs.items()}
        
        # Get predictions
        with torch.no_grad():
            outputs = self.model(**inputs)
            logits = outputs.logits
            probabilities = self.softmax(logits)
        
        # Get predicted class
        predicted_id = torch.argmax(probabilities, dim=1).item()
        confidence = probabilities[0][predicted_id].item()
        predicted_label = self.label_names[predicted_id]
        
        # Get all class probabilities
        all_probs = probabilities[0].cpu().numpy()
        
        result = {
            'text': text,
            'predicted_label': predicted_label,
            'confidence': confidence,
            'all_probabilities': {label: prob for label, prob in zip(self.label_names, all_probs)}
        }
        
        # Get attention weights if requested
        if return_attention:
            with torch.no_grad():
                attention_outputs = self.base_model(**inputs)
                attentions = attention_outputs.attentions[-1]  # Last layer
                avg_attention = attentions.mean(dim=1).squeeze()
                cls_attention = avg_attention[0, :].cpu().numpy()
                
                # Get tokens
                tokens = self.tokenizer.convert_ids_to_tokens(inputs['input_ids'][0])
                
                # Filter padding
                valid_indices = [i for i, t in enumerate(tokens) if t != '[PAD]']
                filtered_tokens = [tokens[i] for i in valid_indices]
                filtered_attention = cls_attention[valid_indices]
                
                # Get top tokens
                sorted_indices = np.argsort(filtered_attention)[::-1]
                top_n = min(5, len(filtered_tokens))
                top_tokens = [filtered_tokens[i] for i in sorted_indices[:top_n]]
                top_weights = [filtered_attention[i] for i in sorted_indices[:top_n]]
                
                result['highlighted_tokens'] = list(zip(top_tokens, top_weights))
                result['all_tokens'] = filtered_tokens
                result['all_attention_weights'] = filtered_attention.tolist()
        
        return result
    
    def batch_analyze(self, texts):
        """Analyze multiple texts in batch"""
        return [self.analyze(text) for text in texts]

# Test the analyzer
