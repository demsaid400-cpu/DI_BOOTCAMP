# Load the base model for attention extraction
base_model = AutoModel.from_pretrained('./best_model', output_attentions=True)
base_model.eval()

def get_attention_weights(text, model, tokenizer, max_length=128):
    """Extract attention weights for a given text"""
    # Tokenize
    inputs = tokenizer(
        text,
        truncation=True,
        padding='max_length',
        max_length=max_length,
        return_tensors='pt'
    )
    
    # Get model outputs with attention
    with torch.no_grad():
        outputs = model(**inputs)
    
    # Extract attention weights (last layer)
    # Shape: (batch, layers, heads, seq_len, seq_len)
    attentions = outputs.attentions[-1]  # Last layer
    # Average across heads
    avg_attention = attentions.mean(dim=1).squeeze()  # Shape: (seq_len, seq_len)
    
    # Get tokens
    tokens = tokenizer.convert_ids_to_tokens(inputs['input_ids'][0])
    
    return avg_attention, tokens

def visualize_attention(text, attention_weights, tokens):
    """Visualize attention from [CLS] token to other tokens"""
    # Get attention from [CLS] token (position 0)
    cls_attention = attention_weights[0, :].numpy()
    
    # Filter out padding tokens
    valid_indices = [i for i, t in enumerate(tokens) if t != '[PAD]']
    filtered_tokens = [tokens[i] for i in valid_indices]
    filtered_attention = cls_attention[valid_indices]
    
    # Sort by attention weight
    sorted_indices = np.argsort(filtered_attention)[::-1]
    top_n = min(10, len(filtered_tokens))
    top_tokens = [filtered_tokens[i] for i in sorted_indices[:top_n]]
    top_weights = [filtered_attention[i] for i in sorted_indices[:top_n]]
    
    # Create visualization
    fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(14, 6))
    
    # Bar chart of top tokens
    colors = plt.cm.RdBu_r(np.linspace(0.2, 0.8, len(top_tokens)))[::-1]
    bars = ax1.barh(range(len(top_tokens)), top_weights, color=colors)
    ax1.set_yticks(range(len(top_tokens)))
    ax1.set_yticklabels(top_tokens)
    ax1.set_xlabel('Attention Weight')
    ax1.set_title('Top 10 Tokens Attended by [CLS]')
    ax1.invert_yaxis()
    
    # Heatmap of all tokens
    token_labels = [t if i % 5 == 0 else '' for i, t in enumerate(filtered_tokens)]
    ax2.bar(range(len(filtered_tokens)), filtered_attention, alpha=0.7, color='steelblue')
    ax2.set_xticks(range(0, len(filtered_tokens), 5))
    ax2.set_xticklabels([filtered_tokens[i] if i < len(filtered_tokens) else '' 
                         for i in range(0, len(filtered_tokens), 5)], rotation=45)
    ax2.set_xlabel('Token Position')
    ax2.set_ylabel('Attention Weight from [CLS]')
    ax2.set_title('Full Attention Distribution')
    ax2.grid(True, alpha=0.3)
    
    plt.suptitle(f'Attention Visualization\n"{text}"', fontsize=12)
    plt.tight_layout()
    plt.savefig('./attention_visualization.png', dpi=150)
    plt.show()
    
    return top_tokens, top_weights

