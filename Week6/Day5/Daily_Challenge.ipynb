# Calibration analysis
def calculate_calibration(y_true, y_pred, confidences, n_bins=10):
    """Calculate calibration metrics"""
    bin_boundaries = np.linspace(0, 1, n_bins + 1)
    bin_confidences = []
    bin_accuracies = []
    bin_counts = []
    
    for i in range(n_bins):
        bin_lower = bin_boundaries[i]
        bin_upper = bin_boundaries[i + 1]
        in_bin = (confidences >= bin_lower) & (confidences < bin_upper)
        bin_count = np.sum(in_bin)
        bin_counts.append(bin_count)
        
        if bin_count > 0:
            bin_accuracy = np.mean(y_true[in_bin] == y_pred[in_bin])
            bin_confidence = np.mean(confidences[in_bin])
            bin_accuracies.append(bin_accuracy)
            bin_confidences.append(bin_confidence)
        else:
            bin_accuracies.append(0)
            bin_confidences.append(0)
    
    return np.array(bin_confidences), np.array(bin_accuracies), np.array(bin_counts)

# Calculate calibration
bin_conf, bin_acc, bin_counts = calculate_calibration(
    test_labels, predicted_classes, max_confidences
)

# Plot calibration curve
plt.figure(figsize=(10, 6))
non_empty_bins = bin_counts > 0
plt.plot(bin_conf[non_empty_bins], bin_acc[non_empty_bins], 
         marker='o', linewidth=2, label='Model calibration')
plt.plot([0, 1], [0, 1], 'k--', label='Perfect calibration')
plt.xlabel('Confidence')
plt.ylabel('Accuracy')
plt.title('Calibration Curve')
plt.grid(True, alpha=0.3)
plt.legend()
plt.xlim(0, 1)
plt.ylim(0, 1)
plt.tight_layout()
plt.savefig('./calibration_curve.png', dpi=150)
plt.show()

print("\nCalibration Analysis:")
if mean_conf > test_accuracy:
    print(f" Model appears OVER-confident (mean conf: {mean_conf:.3f} > accuracy: {test_accuracy:.3f})")
elif mean_conf < test_accuracy:
    print(f" Model appears UNDER-confident (mean conf: {mean_conf:.3f} < accuracy: {test_accuracy:.3f})")
else:
    print(f" Model is well-calibrated (mean conf: {mean_conf:.3f} ≈ accuracy: {test_accuracy:.3f})")

